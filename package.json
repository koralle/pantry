{
  "name": "@pantry/monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "cf-typegen": "wrangler types",
    "deploy": "bun run build && wrangler deploy",
    "dev": "vite dev --port 3000",
    "format": "oxfmt . --write",
    "format:check": "oxfmt . --check",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "migrate:dev": "bun dotenvx run -f .env.development -- bun drizzle-kit migrate",
    "preview": "bun run build && vite preview",
    "spec:build": "tsp compile api-spec/main.tsp",
    "spec:build:watch": "tsp compile api-spec/main.tsp --watch",
    "spec:format": "bun run spec:format:fix",
    "spec:format:check": "tsp format api-spec/main.tsp --check",
    "spec:format:fix": "tsp format api-spec/main.tsp",
    "studio:dev": "bun dotenvx run -f .env.development -- bun drizzle-kit studio",
    "test": "vitest run",
    "typecheck": "tsgo"
  },
  "dependencies": {
    "@base-ui/react": "1.5.0",
    "@better-auth/drizzle-adapter": "1.6.14",
    "@cloudflare/vite-plugin": "1.39.0",
    "@formisch/react": "0.5.0",
    "@libsql/client": "0.17.3",
    "@tanstack/react-devtools": "0.10.5",
    "@tanstack/react-query": "5.101.0",
    "@tanstack/react-query-devtools": "5.101.0",
    "@tanstack/react-router": "1.170.10",
    "@tanstack/react-router-devtools": "1.167.0",
    "@tanstack/react-router-ssr-query": "1.167.1",
    "@tanstack/react-start": "1.168.18",
    "@tanstack/router-plugin": "1.168.13",
    "better-auth": "1.6.14",
    "dexie": "4.4.3",
    "drizzle-orm": "1.0.0-rc.3",
    "hono": "4.12.23",
    "lucide-react": "1.17.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "valibot": "1.4.1"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "0.16.13",
    "@dotenvx/dotenvx": "1.71.0",
    "@t3-oss/env-core": "0.13.11",
    "@tanstack/devtools-vite": "0.7.0",
    "@tsconfig/strictest": "2.0.8",
    "@tursodatabase/database": "0.6.1",
    "@types/node": "25.9.1",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260527.2",
    "@typespec/compiler": "1.12.0",
    "@typespec/http": "1.12.0",
    "@typespec/openapi": "1.12.0",
    "@typespec/openapi3": "1.12.0",
    "@typespec/rest": "0.82.0",
    "@vitejs/plugin-react": "6.0.2",
    "drizzle-kit": "1.0.0-rc.3",
    "lefthook": "2.1.9",
    "oxfmt": "0.52.0",
    "oxlint": "1.67.0",
    "oxlint-tsgolint": "0.23.0",
    "typescript": "6.0.3",
    "vite": "8.0.14",
    "vitest": "4.1.8",
    "wrangler": "4.95.0"
  },
  "overrides": {
    "@tanstack/query-core": "5.100.11"
  }
}
