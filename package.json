{
  "name": "@pantry/monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "cf-typegen": "wrangler types",
    "deploy": "pnpm run build && wrangler deploy",
    "dev": "pnpm vite dev --port 3000",
    "format": "oxfmt . --write",
    "format:check": "oxfmt . --check",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "migrate:dev": "pnpm dotenvx run -f .env.development -- pnpm drizzle-kit migrate",
    "preview": "pnpm run build && vite preview",
    "spec:build": "tsp compile api-spec/main.tsp",
    "spec:build:watch": "tsp compile api-spec/main.tsp --watch",
    "spec:format": "pnpm run spec:format:fix",
    "spec:format:check": "tsp format api-spec/main.tsp --check",
    "spec:format:fix": "tsp format api-spec/main.tsp",
    "studio:dev": "pnpm dotenvx run -f .env.development -- pnpm drizzle-kit studio",
    "test": "vitest run",
    "typecheck": "tsgo"
  },
  "dependencies": {
    "@base-ui/react": "catalog:ui",
    "@better-auth/drizzle-adapter": "catalog:authentication",
    "@cloudflare/vite-plugin": "catalog:build",
    "@formisch/react": "catalog:form",
    "@libsql/client": "catalog:database",
    "@tanstack/react-devtools": "catalog:debug",
    "@tanstack/react-query": "catalog:framework",
    "@tanstack/react-query-devtools": "catalog:debug",
    "@tanstack/react-router": "catalog:framework",
    "@tanstack/react-router-devtools": "catalog:debug",
    "@tanstack/react-router-ssr-query": "catalog:framework",
    "@tanstack/react-start": "catalog:framework",
    "@tanstack/router-plugin": "catalog:framework",
    "better-auth": "catalog:authentication",
    "drizzle-orm": "catalog:database",
    "lucide-react": "catalog:ui",
    "react": "catalog:react",
    "react-dom": "catalog:react",
    "valibot": "catalog:validation"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "catalog:test",
    "@dotenvx/dotenvx": "catalog:envvars",
    "@t3-oss/env-core": "catalog:envvars",
    "@tanstack/devtools-vite": "catalog:debug",
    "@tsconfig/strictest": "catalog:typescript",
    "@tursodatabase/database": "catalog:database",
    "@types/node": "catalog:runtime",
    "@types/react": "catalog:react",
    "@types/react-dom": "catalog:react",
    "@typescript/native-preview": "catalog:typescript",
    "@typespec/compiler": "catalog:typespec",
    "@typespec/http": "catalog:typespec",
    "@typespec/openapi": "catalog:typespec",
    "@typespec/openapi3": "catalog:typespec",
    "@typespec/rest": "catalog:typespec",
    "@vitejs/plugin-react": "catalog:build",
    "drizzle-kit": "catalog:database",
    "lefthook": "catalog:githooks",
    "oxfmt": "catalog:format",
    "oxlint": "catalog:lint",
    "oxlint-tsgolint": "catalog:lint",
    "typescript": "catalog:typescript",
    "vite": "catalog:build",
    "vitest": "catalog:test",
    "wrangler": "catalog:runtime"
  },
  "engines": {
    "node": ">=24.15.0",
    "pnpm": "11"
  },
  "packageManager": "pnpm@11.5.3"
}
